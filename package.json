{
  "name": "qwosid",
  "private": true,
  "version": "1.0.1",
  "description": "A desktop story organiser for writers — characters, chapters, outlines, relationships, and screenplay PDF export.",
  "author": "Nicolas Giammarresi",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "launch": "npm run build && electron-builder --win --dir && node flip-fuses.mjs && start release\\win-unpacked\\Qwosid.exe",
    "dist": "npm run build && electron-builder --win portable && node flip-fuses.mjs",
    "release": "npm run dist && node release.mjs"
  },
  "build": {
    "appId": "com.qwosid.app",
    "productName": "Qwosid",
    "asar": true,
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": false,
      "onlyLoadAppFromAsar": false
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico",
      "artifactName": "Qwosid.exe"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  }
}
